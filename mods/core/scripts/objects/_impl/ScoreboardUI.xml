<Defaults>
    <Button fontSize="18" textColor="#FFFFFF" colors="#353839|#353839|#353839|#353839" />
</Defaults>

<VerticalLayout position="0 0 -20" width="350" height="200">
    <HorizontalLayout height="35">
        <Button id="redInitiativeButton" onClick="setInitiative" textColor="Red" colors="#353839|#353839|#353839|White" preferredWidth="105">
            Red
        </Button>
        <Button interactible="false" preferredWidth="90">
            Initiative
        </Button>
        <Button id="blueInitiativeButton" onClick="setInitiative" textColor="Blue" colors="#353839|#353839|#353839|White" preferredWidth="105">
            Blue
        </Button>
    </HorizontalLayout>
    <Button id="roundButton" onClick="toggleRound">Round 1</Button>
    <Button id="availableSupplyButton" onClick="toggleAvailableSupply">Available Supply 6</Button>
    <HorizontalLayout height="35">
        <Button id="redSupply" onClick="toggleRedSupply">Red Supply 0</Button>
        <Button id="blueSupply" onClick="toggleBlueSupply">Blue Supply 0</Button>
    </HorizontalLayout>
    <HorizontalLayout height="50">
        <Button id="redSupplyDestroyed" onClick="toggleRedSupplyDestroyed">Red Supply Destroyed 0</Button>
        <Button id="blueSupplyDestroyed" onClick="toggleBlueSupplyDestroyed">Blue Supply Destroyed 0</Button>
    </HorizontalLayout>
</VerticalLayout>